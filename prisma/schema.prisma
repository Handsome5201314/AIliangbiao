  @@index([provider, isActive])
  @@index([serviceType, isActive])
  @@index([secretHash])
}

model SystemConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique
  configValue String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SpeechUsage {
  id             String    @id @default(cuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioDuration  Float?
  audioSize      Int?
  provider       String
  model          String
  transcriptText String?
  confidence     Float?
  context        String?
  success        Boolean   @default(true)
  costTokens     Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([provider, createdAt])
}

model AgentpitIdentity {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerUserId String   @unique
  email          String?
  displayName    String?
  avatarUrl      String?
  rawProfile     Json?
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([email])
}

model TokenUsage {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  clientId       String
  agentId        String
  tokensUsed     Int
  inputTokens    Int?
  outputTokens   Int?
  startedAt      DateTime
  endedAt        DateTime
  modelName      String?
  requestId      String?
  requestPath    String?
  responseTimeMs Int?
  responseStatus Int?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([clientId, createdAt])
  @@index([agentId, createdAt])
  @@index([requestId])
}

model AgentProfileState {
  id               String                @id @default(cuid())
  memberProfileId  String                @unique
  memberProfile    MemberProfile         @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  version          Int                   @default(1)
  summary          Json
  snapshotV1       Json?
  lastAssessmentAt DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  versions         AgentProfileVersion[]

  @@index([updatedAt])
}

model AgentProfileVersion {
  id                  String            @id @default(cuid())
  agentProfileStateId String
  agentProfileState   AgentProfileState @relation(fields: [agentProfileStateId], references: [id], onDelete: Cascade)
  version             Int
  trigger             String
  summary             Json
  snapshotV1          Json?
  createdAt           DateTime          @default(now())

  @@index([agentProfileStateId, version])
  @@index([createdAt])
}

model AgentExecution {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberProfileId String?
  memberProfile  MemberProfile?       @relation(fields: [memberProfileId], references: [id], onDelete: SetNull)
  agentSessionId String?
  accountType    String
  goal           String
  status         String               @default("AWAITING_CONFIRMATION")
  plan           Json
  result         Json?
  errorMessage   String?
  confirmedAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  steps          AgentExecutionStep[]

  @@index([userId, createdAt])
  @@index([memberProfileId, createdAt])
  @@index([status, createdAt])
}

model AgentExecutionStep {
  id            String          @id @default(cuid())
  executionId   String
  execution     AgentExecution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepOrder     Int
  toolId        String
  summary       String?
  riskLevel     String          @default("low")
  status        String          @default("PENDING")
  input         Json?
  output        Json?
  errorMessage  String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([executionId, stepOrder])
  @@index([status, createdAt])
}

model DoctorBotConfig {
  id                     String                 @id @default(cuid())
  doctorProfileId        String                 @unique
  doctorProfile          DoctorProfile          @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  assistantName          String
  avatarUrl              String?
  welcomeMessage         String?
  publicSlug             String                 @unique
  fastgptBaseUrl         String
  fastgptApiKeyEncrypted String?
  enabledScaleIds        Json
  status                 String                 @default("draft")
  lastValidatedAt        DateTime?
  validationStatus       String?
  lastValidationError    String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  chatSessions           DoctorBotChatSession[]

  @@index([status, updatedAt])
}

model DoctorBotChatSession {
  id               String          @id @default(cuid())
  doctorBotId      String
  doctorBot        DoctorBotConfig @relation(fields: [doctorBotId], references: [id], onDelete: Cascade)
  visitorSessionId String
  chatId           String          @unique
  deviceId         String
  memberProfileId  String?
  memberProfile    MemberProfile?  @relation(fields: [memberProfileId], references: [id], onDelete: SetNull)
  status           String          @default("active")
  messageCount     Int             @default(0)
  lastError        String?
  lastActiveAt     DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([doctorBotId, visitorSessionId])
  @@index([status, lastActiveAt])
  @@index([memberProfileId, lastActiveAt])
}

model DoctorNeonateArchive {
  id                  String                     @id @default(cuid())
  doctorProfileId     String
  doctorProfile       DoctorProfile              @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  babyName            String
  sex                 String
  birthGestationWeeks Int
  birthGestationDays  Int
  birthDate           DateTime
  birthTimeMinutes    Int?
  normalizedMatchKey  String
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  growthRecords       DoctorNeonateGrowthRecord[]
  accessGrants        NeonateArchiveAccessGrant[]

  @@index([doctorProfileId, updatedAt])
  @@index([doctorProfileId, normalizedMatchKey])
  @@index([doctorProfileId, babyName])
}

model DoctorNeonateGrowthRecord {
  id                    String               @id @default(cuid())
  archiveId             String
  archive               DoctorNeonateArchive @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  recordDate            DateTime
  recordTimeMinutes     Int?
  length                Float?
  weight                Float?
  headCircumference     Float?
  bilirubinUmol         Float?
  bilirubinContext      DoctorNeonateBilirubinContext?
  currentGestationWeeks Int
  currentGestationDays  Int
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([archiveId, recordDate, recordTimeMinutes])
  @@index([archiveId, recordDate, recordTimeMinutes])
}
