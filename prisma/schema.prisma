generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  REGISTERED
  VIP
}

enum AuthVerificationPurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum AccountType {
  PATIENT
  DOCTOR
}

enum MemberRelation {
  SELF
  CHILD
  PARENT
  SPOUSE
  SIBLING
  OTHER
}

enum LanguagePreference {
  ZH
  EN
}

enum CareTeamRole {
  LEAD
  MEMBER
}

enum CareAccessRole {
  COLLABORATOR
  READONLY
}

enum CollaborationResourceType {
  PATIENT_MEMBER
  NEONATE_ARCHIVE
  CARE_TEAM
}

enum DoctorVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrganizationStatus {
  ACTIVE
  DISABLED
}

enum HermesProfileOwnerType {
  ORGANIZATION
  DOCTOR
}

enum HermesProfileStatus {
  DRAFT
  READY
  DEGRADED
  DISABLED
}

enum KnowledgeScopeType {
  PLATFORM
  ORGANIZATION
  DOCTOR
}

enum KnowledgeReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  ARCHIVED
}

enum AuditActorType {
  USER
  DOCTOR
  ADMIN
  SYSTEM
}

enum AuditTargetType {
  MEMBER_PROFILE
  KNOWLEDGE_DOC
  QUESTION_EXPLANATION
  EDUCATION_CONTENT
  EDUCATION_DELIVERY
  FOLLOWUP_TASK
  REMINDER_LOG
  AGENT_SESSION
  ORGANIZATION
  HERMES_PROFILE
}

enum CareAssignmentStatus {
  ACTIVE
  REVOKED
}

enum DoctorPatientNoteType {
  CLINICAL
  RESEARCH
}

enum ResearchConsentStatus {
  GRANTED
  REVOKED
}

enum ResearchExportFormat {
  CSV
  PDF
  JSON
}

enum ApiKeyPurpose {
  AI
  MCP
}

enum DoctorScaleInviteStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

enum ClinicScreeningSubmissionStatus {
  SUBMITTED
  CLAIMED
  ARCHIVED
}

enum DoctorNeonateBilirubinContext {
  AMBIENT
  PHOTOTHERAPY
}

enum ScaleLicenseStatus {
  UNKNOWN
  INTERNAL_REVIEW
  AUTHORIZED_INTERNAL
  AUTHORIZED_COMMERCIAL
  RESTRICTED
  EXPIRED
}

enum DoctorReviewStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  NEEDS_MORE_INFO
  SUPERSEDED
}

enum AssessmentReportStatus {
  DRAFT
  PENDING_DOCTOR_REVIEW
  APPROVED
  REJECTED
  SUPERSEDED
}

enum ReportTemplateStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum EducationDeliveryStatus {
  PENDING
  DELIVERED
  READ
  CONFIRMED
  CANCELLED
}

enum FollowUpTaskType {
  ONE_MONTH
  THREE_MONTH
  CUSTOM
}

enum FollowUpTaskStatus {
  PENDING
  REMINDED
  COMPLETED
  CANCELLED
  LOST_TO_FOLLOWUP
}

enum ReminderChannel {
  MANUAL_PHONE
  MANUAL_WECHAT
  IN_PERSON
  OTHER
}

enum ReminderStatus {
  RECORDED
  ACKNOWLEDGED
  FAILED
}

enum ResearchImportBatchStatus {
  DRAFT
  VALIDATED
  IMPORTED
  FAILED
  CANCELLED
}

enum AiDecisionType {
  QUESTION_EXPLANATION
  ANSWER_MAPPING
  LOW_CONFIDENCE_CONFIRMATION
  PARENT_EXPLANATION
  DOCTOR_SUMMARY
  EDUCATION_MATCH
  SAFETY_REVIEW
}

enum McpToolCallStatus {
  SUCCESS
  ERROR
}

model User {
  id                      String               @id @default(cuid())
  role                    UserRole             @default(GUEST)
  accountType             AccountType          @default(PATIENT)
  isGuest                 Boolean              @default(true)
  deviceId                String?              @unique
  phone                   String?              @unique
  email                   String?              @unique
  passwordHash            String?
  dailyUsed               Int                  @default(0)
  dailyLimit              Int                  @default(5)
  totalTokens             Int                  @default(0)
  lastResetAt             DateTime             @default(now())
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  profiles                MemberProfile[]
  assessments             AssessmentHistory[]
  assessmentSessions      AssessmentSession[]
  triageSessions          TriageSession[]
  mcpLogs                 McpLog[]
  apiKeys                 ApiKey[]
  speechUsages            SpeechUsage[]
  tokenUsages             TokenUsage[]
  agentpitIdentities      AgentpitIdentity[]
  doctorProfile           DoctorProfile?
  agentExecutions         AgentExecution[]
  aiInteractions          AiInteraction[]
  reportViews             ReportView[]
  clinicScreenings        ClinicScreeningSubmission[]
  aiToyDeviceBindings     AiToyDeviceBinding[]
  assignedCareAssignments CareAssignment[]     @relation("CareAssignmentAssignedByPatient")
  researchConsentsGranted ResearchConsent[]    @relation("ResearchConsentGrantedByPatient")
  researchExportsRequested ResearchExportLog[] @relation("ResearchExportRequestedByUser")
  researchImportBatchesRequested ResearchImportBatch[] @relation("ResearchImportBatchRequestedByUser")
  aiDecisionLogs         AiDecisionLog[]
  mcpToolLogs            McpToolLog[]
  @@index([role])
  @@index([accountType])
}

model AuthVerificationCode {
  id           String                  @id @default(cuid())
  phone        String
  purpose      AuthVerificationPurpose
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int                     @default(0)
  createdAt    DateTime                @default(now())

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
  @@index([consumedAt])
}

model MemberProfile {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  relation           MemberRelation       @default(SELF)
  languagePreference LanguagePreference   @default(ZH)
  nickname           String
  realName           String?
  contactPhone       String?
  gender             String
  ageMonths          Int?
  pendingClaim       Boolean              @default(false)
  traits             Json
  avatarConfig       Json
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  growthRecords      GrowthRecord[]
  assessments        AssessmentHistory[]
  assessmentSessions AssessmentSession[]
  careAssignments    CareAssignment[]
  doctorNotes        DoctorPatientNote[]
  researchConsent    ResearchConsent?
  researchExports    ResearchExportLog[]
  linkedDoctorInvites DoctorScaleInvite[] @relation("DoctorScaleInviteLinkedMember")
  memberAccessGrants MemberCareAccessGrant[]
  agentProfileState  AgentProfileState?
  agentExecutions    AgentExecution[]
  clinicScreenings   ClinicScreeningSubmission[]
  doctorBotChatSessions DoctorBotChatSession[]
  aiToyDeviceBindings AiToyDeviceBinding[]
  childBaseline      ChildBaseline?
  scaleScores        ScaleScore[]
  followUps          FollowUp[]
  aiInteractions     AiInteraction[]
  reportViews        ReportView[]
  outcome3mRecords   Outcome3m[]
  inpatientRecords   InpatientRecord[]
  doctorReviews      DoctorReview[]
  assessmentReports  AssessmentReport[]
  educationDeliveries EducationDelivery[]
  followUpTasks      FollowUpTask[]
  reminderLogs       ReminderLog[]
  aiDecisionLogs     AiDecisionLog[]

  @@index([userId, relation])
  @@index([contactPhone])
  @@index([realName, gender])
  @@index([pendingClaim])
  @@map("ChildProfile")
}

model AiToyDeviceBinding {
  id              String        @id @default(cuid())
  deviceId        String
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberProfileId String
  memberProfile   MemberProfile @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  status          String        @default("ACTIVE")
  boundAt         DateTime      @default(now())
  unboundAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([deviceId])
  @@index([userId, memberProfileId])
  @@index([status, updatedAt])
}

model AssessmentHistory {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId           String?
  profile             MemberProfile?       @relation(fields: [profileId], references: [id], onDelete: SetNull)
  scaleId             String
  scaleVersion        String               @default("1.0")
  totalScore          Float
  conclusion          String
  answers             Json
  resultDetails       Json?
  inviteId            String?
  invite              DoctorScaleInvite?   @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  source              String               @default("DIRECT")
  respondentRealName  String?
  respondentPhone     String?
  respondentGender    String?
  respondentAgeMonths Int?
  createdAt           DateTime             @default(now())

  doctorNotes         DoctorPatientNote[]
  assessmentSessions  AssessmentSession[]
  clinicScreeningSubmission ClinicScreeningSubmission?
  scaleScores         ScaleScore[]
  followUps           FollowUp[]
  aiInteractions      AiInteraction[]
  reportViews         ReportView[]
  doctorReviews       DoctorReview[]
  assessmentReports   AssessmentReport[]
  educationDeliveries EducationDelivery[]
  baselineFollowUpTasks FollowUpTask[] @relation("FollowUpTaskBaselineHistory")
  completedFollowUpTasks FollowUpTask[] @relation("FollowUpTaskCompletedHistory")
  aiDecisionLogs      AiDecisionLog[]
  mcpToolLogs         McpToolLog[]

  @@index([userId, createdAt])
  @@index([profileId, createdAt])
  @@index([scaleId, scaleVersion])
  @@index([inviteId])
  @@index([respondentPhone, createdAt])
}

model AssessmentSession {
  id                  String                  @id @default(cuid())
  userId              String
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId           String?
  profile             MemberProfile?          @relation(fields: [profileId], references: [id], onDelete: SetNull)
  scaleId             String
  scaleVersion        String                  @default("1.0")
  channel             String?
  language            String                  @default("ZH")
  status              String                  @default("ONGOING")
  publicToken         String?                 @unique
  publicTokenExpiresAt DateTime?
  answers             Json
  currentQuestionIndex Int?                   @default(0)
  totalScore          Float?
  conclusion          String?
  resultDetails       Json?
  assessmentHistoryId String?
  assessmentHistory   AssessmentHistory?      @relation(fields: [assessmentHistoryId], references: [id], onDelete: SetNull)
  callbackDelivery    AssessmentCallbackDelivery?
  scaleScores         ScaleScore[]
  followUps           FollowUp[]
  aiInteractions      AiInteraction[]
  reportViews         ReportView[]
  outcome3mRecords    Outcome3m[]
  doctorReviews       DoctorReview[]
  assessmentReports   AssessmentReport[]
  educationDeliveries EducationDelivery[]
  baselineFollowUpTasks FollowUpTask[] @relation("FollowUpTaskBaselineSession")
  completedFollowUpTasks FollowUpTask[] @relation("FollowUpTaskCompletedSession")
  aiDecisionLogs      AiDecisionLog[]
  mcpToolLogs         McpToolLog[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  completedAt         DateTime?

  @@index([userId, status, updatedAt])
  @@index([profileId, status, updatedAt])
  @@index([scaleId, scaleVersion])
}

model AssessmentCallbackDelivery {
  id                    String            @id @default(cuid())
  assessmentSessionId   String            @unique
  assessmentSession     AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  deviceId              String?
  callbackUrl           String
  callbackSecretEncrypted String?
  callbackMetadata      Json?
  eventType             String            @default("assessment.completed")
  status                String            @default("PENDING")
  attemptCount          Int               @default(0)
  lastAttemptAt         DateTime?
  deliveredAt           DateTime?
  lastError             String?
  payload               Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([status, updatedAt])
}

model Organization {
  id          String             @id @default(cuid())
  name        String
  orgCode     String?            @unique
  status      OrganizationStatus @default(ACTIVE)
  contactName String?
  contactPhone String?
  createdByAdminId String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  doctors      DoctorProfile[]
  hermesProfiles HermesProfile[]

  @@index([status, createdAt])
}

model DoctorProfile {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId     String?
  organization       Organization?             @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  realName           String
  hospitalName       String
  departmentName     String
  title              String
  licenseNo          String                    @unique
  verificationStatus DoctorVerificationStatus  @default(PENDING)
  reviewNotes        String?
  isOrganizationOwner Boolean                  @default(false)
  approvedAt         DateTime?
  approvedByAdminId  String?
  approvedByAdmin    Admin?                    @relation("DoctorApprovedByAdmin", fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  careAssignments    CareAssignment[]
  patientNotes       DoctorPatientNote[]
  researchExports    ResearchExportLog[]
  scaleInvites       DoctorScaleInvite[]
  clinicScreeningPoints ClinicScreeningPoint[]
  clinicScreenings   ClinicScreeningSubmission[]
  doctorBots         DoctorBotConfig[]
  followUps          FollowUp[]
  aiInteractions     AiInteraction[]
  reportViews        ReportView[]
  inpatientRecords   InpatientRecord[]
  doctorReviews      DoctorReview[]
  approvedReports    AssessmentReport[] @relation("AssessmentReportApprovedByDoctor")
  reportTemplates    ReportTemplate[] @relation("ReportTemplateCreatedByDoctor")
  educationContents  EducationContent[] @relation("EducationContentCreatedByDoctor")
  educationDeliveries EducationDelivery[]
  followUpTasks      FollowUpTask[] @relation("FollowUpTaskCreatedByDoctor")
  reminderLogs       ReminderLog[]
  researchImportBatches ResearchImportBatch[] @relation("ResearchImportBatchUploadedByDoctor")
  aiDecisionLogs     AiDecisionLog[]
  neonateArchives    DoctorNeonateArchive[]
  careTeamMemberships CareTeamMembership[]
  grantedMemberAccessGrants MemberCareAccessGrant[] @relation("MemberAccessGrantedByDoctor")
  receivedMemberAccessGrants MemberCareAccessGrant[] @relation("MemberAccessTargetDoctor")
  grantedNeonateAccessGrants NeonateArchiveAccessGrant[] @relation("NeonateAccessGrantedByDoctor")
  receivedNeonateAccessGrants NeonateArchiveAccessGrant[] @relation("NeonateAccessTargetDoctor")
  collaborationAuditLogs DoctorCollaborationAuditLog[] @relation("CollaborationAuditActorDoctor")
  collaborationAuditTargets DoctorCollaborationAuditLog[] @relation("CollaborationAuditTargetDoctor")
  hermesProfile       HermesProfile?

  @@index([verificationStatus])
  @@index([realName])
  @@index([hospitalName, departmentName])
  @@index([organizationId])
}

model HermesProfile {
  id              String                  @id @default(cuid())
  ownerType       HermesProfileOwnerType
  organizationId  String?                 @unique
  organization    Organization?           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  doctorProfileId String?                 @unique
  doctorProfile   DoctorProfile?          @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  displayName     String?
  status          HermesProfileStatus     @default(READY)
  policyJson      Json?
  configJson      Json?
  lastHealthAt    DateTime?
  lastHealthStatus String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  knowledgeDocs   KnowledgeDoc[]

  @@index([ownerType, status])
}

model KnowledgeDoc {
  id               String                @id @default(cuid())
  hermesProfileId  String?
  hermesProfile    HermesProfile?        @relation(fields: [hermesProfileId], references: [id], onDelete: SetNull)
  scopeType        KnowledgeScopeType    @default(PLATFORM)
  organizationId   String?
  doctorProfileId  String?
  title            String
  slug             String?
  sourceType       String                @default("MARKDOWN")
  summary          String?
  rawMd            String
  renderedHtml     String?
  language         String                @default("zh")
  status           KnowledgeReviewStatus @default(DRAFT)
  sourceFileName   String?
  uploadedByUserId String?
  reviewedByAdminId String?
  reviewedAt       DateTime?
  reviewComment    String?
  metadataJson     Json?
  chunkCount       Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  chunks               KnowledgeChunk[]
  questionExplanations QuestionExplanation[]
  educationContents    EducationContent[]

  @@index([scopeType, status, language, createdAt])
  @@index([organizationId, doctorProfileId, status])
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  docId      String
  doc        KnowledgeDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  chunkIndex Int
  scaleId    String?
  questionId String?
  contentText String
  searchText String?
  tokenCount Int?
  embedding  Unsupported("vector")?
  metadataJson Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([docId, chunkIndex])
  @@index([docId, createdAt])
}

model QuestionExplanation {
  id              String                @id @default(cuid())
  sourceDocId     String?
  sourceDoc       KnowledgeDoc?         @relation(fields: [sourceDocId], references: [id], onDelete: SetNull)
  scaleId         String
  questionId      Int
  lang            String                @default("zh")
  scopeType       KnowledgeScopeType    @default(PLATFORM)
  organizationId  String?
  doctorProfileId String?
  title           String?
  contentMd       String
  status          KnowledgeReviewStatus @default(DRAFT)
  priority        Int                   @default(100)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([scaleId, questionId, lang, scopeType, status, priority])
  @@index([organizationId, doctorProfileId, status])
}

model AuditLog {
  id                   String          @id @default(cuid())
  organizationId       String?
  actorType            AuditActorType
  actorUserId          String?
  actorDoctorProfileId String?
  actorAdminId         String?
  memberProfileId      String?
  targetType           AuditTargetType
  targetId             String?
  action               String
  details              Json?
  createdAt            DateTime        @default(now())

  @@index([memberProfileId, createdAt])
  @@index([organizationId, createdAt])
  @@index([action, createdAt])
}

model DoctorScaleInvite {
  id              String                  @id @default(cuid())
  token           String                  @unique
  doctorProfileId String
  doctorProfile   DoctorProfile           @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  scaleId         String
  scaleVersion    String                  @default("1.0")
  status          DoctorScaleInviteStatus @default(ACTIVE)
  expiresAt       DateTime
  usedAt          DateTime?
  linkedMemberId  String?
  linkedMember    MemberProfile?          @relation("DoctorScaleInviteLinkedMember", fields: [linkedMemberId], references: [id], onDelete: SetNull)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  assessments     AssessmentHistory[]

  @@index([doctorProfileId, status, createdAt])
  @@index([expiresAt])
  @@index([linkedMemberId])
}

model ClinicScreeningPoint {
  id                   String                     @id @default(cuid())
  name                 String
  code                 String                     @unique
  collectionSource     String                     @default("IN_HOSPITAL")
  locationLabel        String?
  departmentLabel      String?
  ownerDoctorProfileId String
  ownerDoctorProfile   DoctorProfile              @relation(fields: [ownerDoctorProfileId], references: [id])
  isActive             Boolean                    @default(true)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  qrs                  ClinicScaleQr[]
  screenings           ClinicScreeningSubmission[]

  @@index([ownerDoctorProfileId, isActive])
}

model ClinicScaleQr {
  id         String                     @id @default(cuid())
  pointId    String
  point      ClinicScreeningPoint       @relation(fields: [pointId], references: [id], onDelete: Cascade)
  scaleId    String
  slug       String                     @unique
  isActive   Boolean                    @default(true)
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  screenings ClinicScreeningSubmission[]

  @@index([pointId, isActive])
  @@index([scaleId, isActive])
}

model ClinicScreeningSubmission {
  id                  String                         @id @default(cuid())
  screeningCode       String                         @unique
  clinicScaleQrId     String
  clinicScaleQr       ClinicScaleQr                  @relation(fields: [clinicScaleQrId], references: [id], onDelete: Cascade)
  pointId             String
  point               ClinicScreeningPoint           @relation(fields: [pointId], references: [id], onDelete: Cascade)
  doctorProfileId     String
  doctorProfile       DoctorProfile                  @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?                          @relation(fields: [userId], references: [id], onDelete: SetNull)
  memberProfileId     String?
  memberProfile       MemberProfile?                 @relation(fields: [memberProfileId], references: [id], onDelete: SetNull)
  guestSessionId      String?
  respondentName      String
  respondentGender    String
  respondentAgeMonths Int
  answers             Json
  resultSummary       Json
  assessmentHistoryId String?                        @unique
  assessmentHistory   AssessmentHistory?             @relation(fields: [assessmentHistoryId], references: [id], onDelete: SetNull)
  status              ClinicScreeningSubmissionStatus @default(SUBMITTED)
  claimedAt           DateTime?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  @@index([doctorProfileId, createdAt])
  @@index([pointId, createdAt])
  @@index([clinicScaleQrId, createdAt])
  @@index([status, createdAt])
  @@index([guestSessionId])
}

model CareAssignment {
  id                    String               @id @default(cuid())
  memberProfileId       String
  memberProfile         MemberProfile        @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  doctorProfileId       String
  doctorProfile         DoctorProfile        @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  assignedByPatientUserId String
  assignedByPatientUser User                 @relation("CareAssignmentAssignedByPatient", fields: [assignedByPatientUserId], references: [id], onDelete: Cascade)
  status                CareAssignmentStatus @default(ACTIVE)
  startedAt             DateTime             @default(now())
  endedAt               DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([memberProfileId, status])
  @@index([doctorProfileId, status])
}

model CareTeam {
  id                    String                      @id @default(cuid())
  name                  String
  hospitalName          String
  departmentName        String
  isActive              Boolean                     @default(true)
  createdByAdminId      String
  createdByAdmin        Admin                       @relation("CareTeamCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: Cascade)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  memberships           CareTeamMembership[]
  memberAccessGrants    MemberCareAccessGrant[]
  neonateAccessGrants   NeonateArchiveAccessGrant[]
  collaborationAuditLogs DoctorCollaborationAuditLog[]

  @@index([hospitalName, departmentName, isActive])
  @@index([createdByAdminId, createdAt])
}

model CareTeamMembership {
  id              String        @id @default(cuid())
  teamId          String
  team            CareTeam      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  teamRole        CareTeamRole
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([teamId, doctorProfileId])
  @@index([doctorProfileId, updatedAt])
}

model MemberCareAccessGrant {
  id                       String         @id @default(cuid())
  memberProfileId          String
  memberProfile            MemberProfile  @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  doctorProfileId          String
  doctorProfile            DoctorProfile  @relation("MemberAccessTargetDoctor", fields: [doctorProfileId], references: [id], onDelete: Cascade)
  sourceTeamId             String
  sourceTeam               CareTeam       @relation(fields: [sourceTeamId], references: [id], onDelete: Cascade)
  accessRole               CareAccessRole
  grantedByDoctorProfileId String
  grantedByDoctorProfile   DoctorProfile  @relation("MemberAccessGrantedByDoctor", fields: [grantedByDoctorProfileId], references: [id], onDelete: Cascade)
  revokedAt                DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([memberProfileId, revokedAt])
  @@index([doctorProfileId, revokedAt])
  @@index([sourceTeamId, revokedAt])
}

model NeonateArchiveAccessGrant {
  id                       String               @id @default(cuid())
  archiveId                String
  archive                  DoctorNeonateArchive @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  doctorProfileId          String
  doctorProfile            DoctorProfile        @relation("NeonateAccessTargetDoctor", fields: [doctorProfileId], references: [id], onDelete: Cascade)
  sourceTeamId             String
  sourceTeam               CareTeam             @relation(fields: [sourceTeamId], references: [id], onDelete: Cascade)
  accessRole               CareAccessRole
  grantedByDoctorProfileId String
  grantedByDoctorProfile   DoctorProfile        @relation("NeonateAccessGrantedByDoctor", fields: [grantedByDoctorProfileId], references: [id], onDelete: Cascade)
  revokedAt                DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  @@index([archiveId, revokedAt])
  @@index([doctorProfileId, revokedAt])
  @@index([sourceTeamId, revokedAt])
}

model DoctorCollaborationAuditLog {
  id                    String                    @id @default(cuid())
  resourceType          CollaborationResourceType
  resourceId            String
  action                String
  actorDoctorProfileId  String?
  actorDoctorProfile    DoctorProfile?            @relation("CollaborationAuditActorDoctor", fields: [actorDoctorProfileId], references: [id], onDelete: SetNull)
  targetDoctorProfileId String?
