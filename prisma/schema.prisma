generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  REGISTERED
  VIP
}

enum AuthVerificationPurpose {
  REGISTER
  LOGIN
  RESET_PASSWORD
}

enum AccountType {
  PATIENT
  DOCTOR
}

enum MemberRelation {
  SELF
  CHILD
  PARENT
  SPOUSE
  SIBLING
  OTHER
}

enum LanguagePreference {
  ZH
  EN
}

enum CareTeamRole {
  LEAD
  MEMBER
}

enum CareAccessRole {
  COLLABORATOR
  READONLY
}

enum CollaborationResourceType {
  PATIENT_MEMBER
  NEONATE_ARCHIVE
  CARE_TEAM
}

enum DoctorVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum CareAssignmentStatus {
  ACTIVE
  REVOKED
}

enum DoctorPatientNoteType {
  CLINICAL
  RESEARCH
}

enum ResearchConsentStatus {
  GRANTED
  REVOKED
}

enum ResearchExportFormat {
  CSV
  PDF
  JSON
}

enum ApiKeyPurpose {
  AI
  MCP
}

enum DoctorScaleInviteStatus {
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

enum ClinicScreeningSubmissionStatus {
  SUBMITTED
  CLAIMED
  ARCHIVED
}

enum DoctorNeonateBilirubinContext {
  AMBIENT
  PHOTOTHERAPY
}

model User {
  id                      String               @id @default(cuid())
  role                    UserRole             @default(GUEST)
  accountType             AccountType          @default(PATIENT)
  isGuest                 Boolean              @default(true)
  deviceId                String?              @unique
  phone                   String?              @unique
  email                   String?              @unique
  passwordHash            String?
  dailyUsed               Int                  @default(0)
  dailyLimit              Int                  @default(5)
  totalTokens             Int                  @default(0)
  lastResetAt             DateTime             @default(now())
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  profiles                MemberProfile[]
  assessments             AssessmentHistory[]
  assessmentSessions      AssessmentSession[]
  triageSessions          TriageSession[]
  mcpLogs                 McpLog[]
  apiKeys                 ApiKey[]
  speechUsages            SpeechUsage[]
  tokenUsages             TokenUsage[]
  agentpitIdentities      AgentpitIdentity[]
  doctorProfile           DoctorProfile?
  agentExecutions         AgentExecution[]
  clinicScreenings        ClinicScreeningSubmission[]
  aiToyDeviceBindings     AiToyDeviceBinding[]
  assignedCareAssignments CareAssignment[]     @relation("CareAssignmentAssignedByPatient")
  researchConsentsGranted ResearchConsent[]    @relation("ResearchConsentGrantedByPatient")
  researchExportsRequested ResearchExportLog[] @relation("ResearchExportRequestedByUser")
  @@index([role])
  @@index([accountType])
}

model AuthVerificationCode {
  id           String                  @id @default(cuid())
  phone        String
  purpose      AuthVerificationPurpose
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int                     @default(0)
  createdAt    DateTime                @default(now())

  @@index([phone, purpose, createdAt])
  @@index([expiresAt])
  @@index([consumedAt])
}

model MemberProfile {
  id                 String               @id @default(cuid())
  userId             String
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  relation           MemberRelation       @default(SELF)
  languagePreference LanguagePreference   @default(ZH)
  nickname           String
  realName           String?
  contactPhone       String?
  gender             String
  ageMonths          Int?
  pendingClaim       Boolean              @default(false)
  traits             Json
  avatarConfig       Json
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  growthRecords      GrowthRecord[]
  assessments        AssessmentHistory[]
  assessmentSessions AssessmentSession[]
  careAssignments    CareAssignment[]
  doctorNotes        DoctorPatientNote[]
  researchConsent    ResearchConsent?
  researchExports    ResearchExportLog[]
  linkedDoctorInvites DoctorScaleInvite[] @relation("DoctorScaleInviteLinkedMember")
  memberAccessGrants MemberCareAccessGrant[]
  agentProfileState  AgentProfileState?
  agentExecutions    AgentExecution[]
  clinicScreenings   ClinicScreeningSubmission[]
  doctorBotChatSessions DoctorBotChatSession[]
  aiToyDeviceBindings AiToyDeviceBinding[]

  @@index([userId, relation])
  @@index([contactPhone])
  @@index([realName, gender])
  @@index([pendingClaim])
  @@map("ChildProfile")
}

model AiToyDeviceBinding {
  id              String        @id @default(cuid())
  deviceId        String
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberProfileId String
  memberProfile   MemberProfile @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  status          String        @default("ACTIVE")
  boundAt         DateTime      @default(now())
  unboundAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([deviceId])
  @@index([userId, memberProfileId])
  @@index([status, updatedAt])
}

model AssessmentHistory {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId           String?
  profile             MemberProfile?       @relation(fields: [profileId], references: [id], onDelete: SetNull)
  scaleId             String
  scaleVersion        String               @default("1.0")
  totalScore          Float
  conclusion          String
  answers             Json
  resultDetails       Json?
  inviteId            String?
  invite              DoctorScaleInvite?   @relation(fields: [inviteId], references: [id], onDelete: SetNull)
  source              String               @default("DIRECT")
  respondentRealName  String?
  respondentPhone     String?
  respondentGender    String?
  respondentAgeMonths Int?
  createdAt           DateTime             @default(now())

  doctorNotes         DoctorPatientNote[]
  assessmentSessions  AssessmentSession[]
  clinicScreeningSubmission ClinicScreeningSubmission?

  @@index([userId, createdAt])
  @@index([profileId, createdAt])
  @@index([scaleId, scaleVersion])
  @@index([inviteId])
  @@index([respondentPhone, createdAt])
}

model AssessmentSession {
  id                  String                  @id @default(cuid())
  userId              String
  user                User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileId           String?
  profile             MemberProfile?          @relation(fields: [profileId], references: [id], onDelete: SetNull)
  scaleId             String
  scaleVersion        String                  @default("1.0")
  channel             String?
  language            String                  @default("ZH")
  status              String                  @default("ONGOING")
  publicToken         String?                 @unique
  publicTokenExpiresAt DateTime?
  answers             Json
  currentQuestionIndex Int?                   @default(0)
  totalScore          Float?
  conclusion          String?
  resultDetails       Json?
  assessmentHistoryId String?
  assessmentHistory   AssessmentHistory?      @relation(fields: [assessmentHistoryId], references: [id], onDelete: SetNull)
  callbackDelivery    AssessmentCallbackDelivery?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  completedAt         DateTime?

  @@index([userId, status, updatedAt])
  @@index([profileId, status, updatedAt])
  @@index([scaleId, scaleVersion])
}

model AssessmentCallbackDelivery {
  id                    String            @id @default(cuid())
  assessmentSessionId   String            @unique
  assessmentSession     AssessmentSession @relation(fields: [assessmentSessionId], references: [id], onDelete: Cascade)
  deviceId              String?
  callbackUrl           String
  callbackSecretEncrypted String?
  callbackMetadata      Json?
  eventType             String            @default("assessment.completed")
  status                String            @default("PENDING")
  attemptCount          Int               @default(0)
  lastAttemptAt         DateTime?
  deliveredAt           DateTime?
  lastError             String?
  payload               Json?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([status, updatedAt])
}

model DoctorProfile {
  id                 String                    @id @default(cuid())
  userId             String                    @unique
  user               User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  realName           String
  hospitalName       String
  departmentName     String
  title              String
  licenseNo          String                    @unique
  verificationStatus DoctorVerificationStatus  @default(PENDING)
  reviewNotes        String?
  approvedAt         DateTime?
  approvedByAdminId  String?
  approvedByAdmin    Admin?                    @relation("DoctorApprovedByAdmin", fields: [approvedByAdminId], references: [id], onDelete: SetNull)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  careAssignments    CareAssignment[]
  patientNotes       DoctorPatientNote[]
  researchExports    ResearchExportLog[]
  scaleInvites       DoctorScaleInvite[]
  clinicScreeningPoints ClinicScreeningPoint[]
  clinicScreenings   ClinicScreeningSubmission[]
  doctorBots         DoctorBotConfig[]
  neonateArchives    DoctorNeonateArchive[]
  careTeamMemberships CareTeamMembership[]
  grantedMemberAccessGrants MemberCareAccessGrant[] @relation("MemberAccessGrantedByDoctor")
  receivedMemberAccessGrants MemberCareAccessGrant[] @relation("MemberAccessTargetDoctor")
  grantedNeonateAccessGrants NeonateArchiveAccessGrant[] @relation("NeonateAccessGrantedByDoctor")
  receivedNeonateAccessGrants NeonateArchiveAccessGrant[] @relation("NeonateAccessTargetDoctor")
  collaborationAuditLogs DoctorCollaborationAuditLog[] @relation("CollaborationAuditActorDoctor")
  collaborationAuditTargets DoctorCollaborationAuditLog[] @relation("CollaborationAuditTargetDoctor")

  @@index([verificationStatus])
  @@index([realName])
  @@index([hospitalName, departmentName])
}

model DoctorScaleInvite {
  id              String                  @id @default(cuid())
  token           String                  @unique
  doctorProfileId String
  doctorProfile   DoctorProfile           @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  scaleId         String
  scaleVersion    String                  @default("1.0")
  status          DoctorScaleInviteStatus @default(ACTIVE)
  expiresAt       DateTime
  usedAt          DateTime?
  linkedMemberId  String?
  linkedMember    MemberProfile?          @relation("DoctorScaleInviteLinkedMember", fields: [linkedMemberId], references: [id], onDelete: SetNull)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  assessments     AssessmentHistory[]

  @@index([doctorProfileId, status, createdAt])
  @@index([expiresAt])
  @@index([linkedMemberId])
}

model ClinicScreeningPoint {
  id                   String                     @id @default(cuid())
  name                 String
  code                 String                     @unique
  collectionSource     String                     @default("IN_HOSPITAL")
  locationLabel        String?
  departmentLabel      String?
  ownerDoctorProfileId String
  ownerDoctorProfile   DoctorProfile              @relation(fields: [ownerDoctorProfileId], references: [id])
  isActive             Boolean                    @default(true)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  qrs                  ClinicScaleQr[]
  screenings           ClinicScreeningSubmission[]

  @@index([ownerDoctorProfileId, isActive])
}

model ClinicScaleQr {
  id         String                     @id @default(cuid())
  pointId    String
  point      ClinicScreeningPoint       @relation(fields: [pointId], references: [id], onDelete: Cascade)
  scaleId    String
  slug       String                     @unique
  isActive   Boolean                    @default(true)
  createdAt  DateTime                   @default(now())
  updatedAt  DateTime                   @updatedAt

  screenings ClinicScreeningSubmission[]

  @@index([pointId, isActive])
  @@index([scaleId, isActive])
}

model ClinicScreeningSubmission {
  id                  String                         @id @default(cuid())
  screeningCode       String                         @unique
  clinicScaleQrId     String
  clinicScaleQr       ClinicScaleQr                  @relation(fields: [clinicScaleQrId], references: [id], onDelete: Cascade)
  pointId             String
  point               ClinicScreeningPoint           @relation(fields: [pointId], references: [id], onDelete: Cascade)
  doctorProfileId     String
  doctorProfile       DoctorProfile                  @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  userId              String?
  user                User?                          @relation(fields: [userId], references: [id], onDelete: SetNull)
  memberProfileId     String?
  memberProfile       MemberProfile?                 @relation(fields: [memberProfileId], references: [id], onDelete: SetNull)
  guestSessionId      String?
  respondentName      String
  respondentGender    String
  respondentAgeMonths Int
  answers             Json
  resultSummary       Json
  assessmentHistoryId String?                        @unique
  assessmentHistory   AssessmentHistory?             @relation(fields: [assessmentHistoryId], references: [id], onDelete: SetNull)
  status              ClinicScreeningSubmissionStatus @default(SUBMITTED)
  claimedAt           DateTime?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  @@index([doctorProfileId, createdAt])
  @@index([pointId, createdAt])
  @@index([clinicScaleQrId, createdAt])
  @@index([status, createdAt])
  @@index([guestSessionId])
}

model CareAssignment {
  id                    String               @id @default(cuid())
  memberProfileId       String
  memberProfile         MemberProfile        @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  doctorProfileId       String
  doctorProfile         DoctorProfile        @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  assignedByPatientUserId String
  assignedByPatientUser User                 @relation("CareAssignmentAssignedByPatient", fields: [assignedByPatientUserId], references: [id], onDelete: Cascade)
  status                CareAssignmentStatus @default(ACTIVE)
  startedAt             DateTime             @default(now())
  endedAt               DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([memberProfileId, status])
  @@index([doctorProfileId, status])
}

model CareTeam {
  id                    String                      @id @default(cuid())
  name                  String
  hospitalName          String
  departmentName        String
  isActive              Boolean                     @default(true)
  createdByAdminId      String
  createdByAdmin        Admin                       @relation("CareTeamCreatedByAdmin", fields: [createdByAdminId], references: [id], onDelete: Cascade)
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  memberships           CareTeamMembership[]
  memberAccessGrants    MemberCareAccessGrant[]
  neonateAccessGrants   NeonateArchiveAccessGrant[]
  collaborationAuditLogs DoctorCollaborationAuditLog[]

  @@index([hospitalName, departmentName, isActive])
  @@index([createdByAdminId, createdAt])
}

model CareTeamMembership {
  id              String        @id @default(cuid())
  teamId          String
  team            CareTeam      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  doctorProfileId String
  doctorProfile   DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  teamRole        CareTeamRole
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([teamId, doctorProfileId])
  @@index([doctorProfileId, updatedAt])
}

model MemberCareAccessGrant {
  id                       String         @id @default(cuid())
  memberProfileId          String
  memberProfile            MemberProfile  @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  doctorProfileId          String
  doctorProfile            DoctorProfile  @relation("MemberAccessTargetDoctor", fields: [doctorProfileId], references: [id], onDelete: Cascade)
  sourceTeamId             String
  sourceTeam               CareTeam       @relation(fields: [sourceTeamId], references: [id], onDelete: Cascade)
  accessRole               CareAccessRole
  grantedByDoctorProfileId String
  grantedByDoctorProfile   DoctorProfile  @relation("MemberAccessGrantedByDoctor", fields: [grantedByDoctorProfileId], references: [id], onDelete: Cascade)
  revokedAt                DateTime?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([memberProfileId, revokedAt])
  @@index([doctorProfileId, revokedAt])
  @@index([sourceTeamId, revokedAt])
}

model NeonateArchiveAccessGrant {
  id                       String               @id @default(cuid())
  archiveId                String
  archive                  DoctorNeonateArchive @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  doctorProfileId          String
  doctorProfile            DoctorProfile        @relation("NeonateAccessTargetDoctor", fields: [doctorProfileId], references: [id], onDelete: Cascade)
  sourceTeamId             String
  sourceTeam               CareTeam             @relation(fields: [sourceTeamId], references: [id], onDelete: Cascade)
  accessRole               CareAccessRole
  grantedByDoctorProfileId String
  grantedByDoctorProfile   DoctorProfile        @relation("NeonateAccessGrantedByDoctor", fields: [grantedByDoctorProfileId], references: [id], onDelete: Cascade)
  revokedAt                DateTime?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  @@index([archiveId, revokedAt])
  @@index([doctorProfileId, revokedAt])
  @@index([sourceTeamId, revokedAt])
}

model DoctorCollaborationAuditLog {
  id                    String                    @id @default(cuid())
  resourceType          CollaborationResourceType
  resourceId            String
  action                String
  actorDoctorProfileId  String?
  actorDoctorProfile    DoctorProfile?            @relation("CollaborationAuditActorDoctor", fields: [actorDoctorProfileId], references: [id], onDelete: SetNull)
  targetDoctorProfileId String?
  targetDoctorProfile   DoctorProfile?            @relation("CollaborationAuditTargetDoctor", fields: [targetDoctorProfileId], references: [id], onDelete: SetNull)
  sourceTeamId          String?
  sourceTeam            CareTeam?                 @relation(fields: [sourceTeamId], references: [id], onDelete: SetNull)
  metadata              Json?
  createdAt             DateTime                  @default(now())

  @@index([resourceType, resourceId, createdAt])
  @@index([actorDoctorProfileId, createdAt])
  @@index([sourceTeamId, createdAt])
}

model DoctorPatientNote {
  id                   String                @id @default(cuid())
  memberProfileId      String
  memberProfile        MemberProfile         @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  doctorProfileId      String
  doctorProfile        DoctorProfile         @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  assessmentHistoryId  String?
  assessmentHistory    AssessmentHistory?    @relation(fields: [assessmentHistoryId], references: [id], onDelete: SetNull)
  noteType             DoctorPatientNoteType @default(CLINICAL)
  content              String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([memberProfileId, createdAt])
  @@index([doctorProfileId, createdAt])
  @@index([assessmentHistoryId])
}

model ResearchConsent {
  id                String                @id @default(cuid())
  memberProfileId   String                @unique
  memberProfile     MemberProfile         @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  grantedByUserId   String
  grantedByUser     User                  @relation("ResearchConsentGrantedByPatient", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  status            ResearchConsentStatus @default(GRANTED)
  projectCode       String                @default("CHA-HPI-AI-SCALE-2026")
  consentVersion    String                @default("2026.05.v1")
  consentScope      Json?
  consentTextHash   String?
  signatureName     String?
  guardianName      String?
  guardianRelation  String?
  consentChannel    String                @default("patient_portal")
  grantedAt         DateTime              @default(now())
  revokedAt         DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
}

model ResearchExportLog {
  id                String               @id @default(cuid())
  memberProfileId   String
  memberProfile     MemberProfile        @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  doctorProfileId   String
  doctorProfile     DoctorProfile        @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  requestedByUserId String
  requestedByUser   User                 @relation("ResearchExportRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  format            ResearchExportFormat @default(CSV)
  purpose           String
  exportedFields    Json
  createdAt         DateTime             @default(now())

  @@index([memberProfileId, createdAt])
  @@index([doctorProfileId, createdAt])
}

model McpLog {
  id            String    @id @default(cuid())
  userId        String?
  user          User?     @relation(fields: [userId], references: [id])
  clientId      String
  action        String
  scaleId       String?
  entrypoint    String    @default("legacy")
  createdAt     DateTime  @default(now())

  @@index([entrypoint, createdAt])
}

model GrowthRecord {
  id                  String         @id @default(cuid())
  profileId           String
  profile             MemberProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ageMonths           Int
  gestationalWeek     Int?
  weight              Float?
  height              Float?
  headCircumference   Float?
  weightPercentile    Float?
  heightPercentile    Float?
  headPercentile      Float?
  weightStatus        String?
  heightStatus        String?
  headStatus          String?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([profileId, ageMonths])
  @@index([profileId, gestationalWeek])
}

model TriageSession {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status              String    @default("ONGOING")
  symptoms            Json
  conversationHistory Json
  recommendedScale    String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId, status])
  @@index([updatedAt])
}

model Admin {
  id              String          @id @default(cuid())
  username        String          @unique
  passwordHash    String
  email           String?         @unique
  role            String          @default("admin")
  lastLoginAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  reviewedDoctors DoctorProfile[] @relation("DoctorApprovedByAdmin")
  createdCareTeams CareTeam[]     @relation("CareTeamCreatedByAdmin")
}

model ApiKey {
  id               String    @id @default(cuid())
  userId           String?
  user             User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose          ApiKeyPurpose @default(AI)
  provider         String
  keyName          String
  keyValue         String
  serviceType      String    @default("text")
  customEndpoint   String?
  customModel      String?
  connectionStatus String?   @default("unknown")
  lastTestedAt     DateTime?
  responseTime     Int?
  isActive         Boolean   @default(true)
  lastUsedAt       DateTime?
  usageCount       Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([purpose, isActive])
  @@index([provider, isActive])
  @@index([serviceType, isActive])
}

model SystemConfig {
  id          String   @id @default(cuid())
  configKey   String   @unique
  configValue String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SpeechUsage {
  id             String    @id @default(cuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioDuration  Float?
  audioSize      Int?
  provider       String
  model          String
  transcriptText String?
  confidence     Float?
  context        String?
  success        Boolean   @default(true)
  costTokens     Int       @default(0)
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([provider, createdAt])
}

model AgentpitIdentity {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerUserId String   @unique
  email          String?
  displayName    String?
  avatarUrl      String?
  rawProfile     Json?
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([email])
}

model TokenUsage {
  id             String   @id @default(cuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  clientId       String
  agentId        String
  tokensUsed     Int
  inputTokens    Int?
  outputTokens   Int?
  startedAt      DateTime
  endedAt        DateTime
  modelName      String?
  requestId      String?
  requestPath    String?
  responseTimeMs Int?
  responseStatus Int?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([clientId, createdAt])
  @@index([agentId, createdAt])
  @@index([requestId])
}

model AgentProfileState {
  id               String                @id @default(cuid())
  memberProfileId  String                @unique
  memberProfile    MemberProfile         @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)
  version          Int                   @default(1)
  summary          Json
  snapshotV1       Json?
  lastAssessmentAt DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  versions         AgentProfileVersion[]

  @@index([updatedAt])
}

model AgentProfileVersion {
  id                  String            @id @default(cuid())
  agentProfileStateId String
  agentProfileState   AgentProfileState @relation(fields: [agentProfileStateId], references: [id], onDelete: Cascade)
  version             Int
  trigger             String
  summary             Json
  snapshotV1          Json?
  createdAt           DateTime          @default(now())

  @@index([agentProfileStateId, version])
  @@index([createdAt])
}

model AgentExecution {
  id             String               @id @default(cuid())
  userId         String
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberProfileId String?
  memberProfile  MemberProfile?       @relation(fields: [memberProfileId], references: [id], onDelete: SetNull)
  agentSessionId String?
  accountType    String
  goal           String
  status         String               @default("AWAITING_CONFIRMATION")
  plan           Json
  result         Json?
  errorMessage   String?
  confirmedAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  steps          AgentExecutionStep[]

  @@index([userId, createdAt])
  @@index([memberProfileId, createdAt])
  @@index([status, createdAt])
}

model AgentExecutionStep {
  id            String          @id @default(cuid())
  executionId   String
  execution     AgentExecution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepOrder     Int
  toolId        String
  summary       String?
  riskLevel     String          @default("low")
  status        String          @default("PENDING")
  input         Json?
  output        Json?
  errorMessage  String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([executionId, stepOrder])
  @@index([status, createdAt])
}

model DoctorBotConfig {
  id                     String                 @id @default(cuid())
  doctorProfileId        String                 @unique
  doctorProfile          DoctorProfile          @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  assistantName          String
  avatarUrl              String?
  welcomeMessage         String?
  publicSlug             String                 @unique
  fastgptBaseUrl         String
  fastgptApiKeyEncrypted String
  enabledScaleIds        Json
  status                 String                 @default("draft")
  lastValidatedAt        DateTime?
  validationStatus       String?
  lastValidationError    String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  chatSessions           DoctorBotChatSession[]

  @@index([status, updatedAt])
}

model DoctorBotChatSession {
  id               String          @id @default(cuid())
  doctorBotId      String
  doctorBot        DoctorBotConfig @relation(fields: [doctorBotId], references: [id], onDelete: Cascade)
  visitorSessionId String
  chatId           String          @unique
  deviceId         String
  memberProfileId  String?
  memberProfile    MemberProfile?  @relation(fields: [memberProfileId], references: [id], onDelete: SetNull)
  status           String          @default("active")
  messageCount     Int             @default(0)
  lastError        String?
  lastActiveAt     DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@unique([doctorBotId, visitorSessionId])
  @@index([status, lastActiveAt])
  @@index([memberProfileId, lastActiveAt])
}

model DoctorNeonateArchive {
  id                  String                     @id @default(cuid())
  doctorProfileId     String
  doctorProfile       DoctorProfile              @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  babyName            String
  sex                 String
  birthGestationWeeks Int
  birthGestationDays  Int
  birthDate           DateTime
  birthTimeMinutes    Int?
  normalizedMatchKey  String
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  growthRecords       DoctorNeonateGrowthRecord[]
  accessGrants        NeonateArchiveAccessGrant[]

  @@index([doctorProfileId, updatedAt])
  @@index([doctorProfileId, normalizedMatchKey])
  @@index([doctorProfileId, babyName])
}

model DoctorNeonateGrowthRecord {
  id                    String               @id @default(cuid())
  archiveId             String
  archive               DoctorNeonateArchive @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  recordDate            DateTime
  recordTimeMinutes     Int?
  length                Float?
  weight                Float?
  headCircumference     Float?
  bilirubinUmol         Float?
  bilirubinContext      DoctorNeonateBilirubinContext?
  currentGestationWeeks Int
  currentGestationDays  Int
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([archiveId, recordDate, recordTimeMinutes])
  @@index([archiveId, recordDate, recordTimeMinutes])
}
