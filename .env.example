# Database Configuration (Supabase)
DATABASE_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres"

# AI Service Configuration
# Choose one or both AI providers
DEEPSEEK_API_KEY="your-deepseek-api-key-here"
TENCENT_SECRET_ID="your-tencent-secret-id-here"
TENCENT_SECRET_KEY="your-tencent-secret-key-here"

# Speech Recognition (Tencent Cloud)
TENCENT_SPEECH_SECRET_ID="your-tencent-speech-secret-id"
TENCENT_SPEECH_SECRET_KEY="your-tencent-speech-secret-key"

# Application Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AI 量表系统"

# Session Secret (for session encryption)
SESSION_SECRET="your-random-session-secret-here-at-least-32-characters"

# Admin Configuration (Optional)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Feature Flags
ENABLE_VOICE_INTERACTION="true"
ENABLE_MCP_SERVER="true"

# Performance Configuration
CACHE_TTL="3600"
MAX_CACHE_SIZE="1000"

# Logging
LOG_LEVEL="info"
