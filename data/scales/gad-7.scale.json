  "description": {
    "zh": "用于快速筛查近两周焦虑症状强度的配置化心理量表示例。",
    "en": "A configurable scale example for screening anxiety symptoms over the last two weeks."
  },
  "source": "manifest",
  "category": "Mental Health",
  "tags": ["心理", "焦虑", "配置化"],
  "estimatedMinutes": 3,
  "interactionMode": "full_voice",
  "supportedLanguages": ["zh", "en"],
  "requiresConfirmation": true,
