{
  "name": "ai-scale-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "test": "tsx --test tests/*.test.ts",
    "lint": "eslint .",
    "typecheck": "npm run build",
    "ci:check": "npx prisma validate && npm test",
    "smoke:local": "node scripts/smoke-local.mjs",
    "test:e2e:playwright": "playwright test",
    "dev:services": "docker compose -f docker-compose.dev.yml --env-file .env.local up -d",
    "dev:services:down": "docker compose -f docker-compose.dev.yml --env-file .env.local down",
    "dev:full": "npm run dev:services && npm run dev",
    "secrets:reset": "node scripts/reset-business-secrets.mjs",
    "prisma:generate": "prisma generate",
    "db:dev:up": "docker compose -f docker-compose.dev.yml --env-file .env.local up -d",
    "db:dev:down": "docker compose -f docker-compose.dev.yml --env-file .env.local down",
    "db:dev:push": "prisma db push",
    "db:dev:seed": "node scripts/seed-local-dev.mjs",
    "skill:build": "tsc -p packages/assessment-skill/tsconfig.build.json",
    "skill:start": "node packages/assessment-skill/dist/standalone.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "prisma": "^5.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tencentcloud-sdk-nodejs": "^4.1.211",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.55.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
