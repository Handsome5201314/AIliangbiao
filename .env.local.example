# Local development database
POSTGRES_DB=ai_scale_db
POSTGRES_USER=ai_scale_app
POSTGRES_PASSWORD=replace-with-a-long-random-password

DATABASE_URL="postgresql://ai_scale_app:replace-with-a-long-random-password@127.0.0.1:5432/ai_scale_db"
DIRECT_URL="postgresql://ai_scale_app:replace-with-a-long-random-password@127.0.0.1:5432/ai_scale_db"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000"

SESSION_SECRET="replace-with-a-local-session-secret"
APP_SESSION_SECRET="replace-with-a-local-app-session-secret"
ADMIN_SESSION_SECRET="replace-with-a-local-admin-session-secret"
BUSINESS_SECRET_ENCRYPTION_KEY="replace-with-a-local-business-secret-encryption-key"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="replace-with-a-local-admin-password"

ENABLE_VOICE_INTERACTION="true"
ENABLE_MCP_SERVER="true"
LOG_LEVEL="debug"

PLATFORM_KNOWLEDGE_EMBEDDING_API_KEY="replace-with-a-local-embedding-api-key"
PLATFORM_KNOWLEDGE_EMBEDDING_ENDPOINT="https://api.openai.com/v1/embeddings"
PLATFORM_KNOWLEDGE_EMBEDDING_MODEL="text-embedding-3-small"

# AI provider keys are managed in /admin/apikeys and are stored encrypted in the database.
