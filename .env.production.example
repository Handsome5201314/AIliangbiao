# Core database settings for the PostgreSQL container.
POSTGRES_DB=ai_scale_db
POSTGRES_USER=ai_scale_app
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Prisma should always connect to the internal Docker hostname.
DATABASE_URL=postgresql://ai_scale_app:replace-with-a-long-random-password@db:5432/ai_scale_db
DIRECT_URL=postgresql://ai_scale_app:replace-with-a-long-random-password@db:5432/ai_scale_db

# Public application URLs used by web handoff and callback flows.
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_API_URL=https://example.com
PUBLIC_APP_URL=https://example.com
APP_BASE_URL=https://example.com

# Session and admin secrets. Rotate before first production use.
SESSION_SECRET=replace-with-a-32-byte-random-secret
APP_SESSION_SECRET=replace-with-an-app-session-secret
ADMIN_SESSION_SECRET=replace-with-an-admin-session-secret
BUSINESS_SECRET_ENCRYPTION_KEY=replace-with-a-32-byte-or-longer-business-secret-encryption-key
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Optional third-party integrations. Leave blank if unused.
AGENTPIT_AUTHORIZE_URL=https://app.agentpit.io/api/oauth/authorize
AGENTPIT_TOKEN_URL=https://app.agentpit.io/api/oauth/token
AGENTPIT_USERINFO_URL=https://app.agentpit.io/api/oauth/userinfo
AGENTPIT_CLIENT_ID=
AGENTPIT_CLIENT_SECRET=
AGENTPIT_REDIRECT_URI=https://example.com/api/auth/agentpit/callback

DEEPSEEK_API_KEY=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SPEECH_SECRET_ID=
TENCENT_SPEECH_SECRET_KEY=

ADMIN_USERNAME=admin
ENABLE_VOICE_INTERACTION=true
ENABLE_MCP_SERVER=true
CACHE_TTL=3600
MAX_CACHE_SIZE=1000
LOG_LEVEL=info

# Hermes API Server settings. In the default Docker Compose deployment the app
# talks to the internal `hermes` service over the internal Docker network.
HERMES_API_SERVER_BASE_URL=http://hermes:8642/v1
HERMES_API_SERVER_KEY=replace-with-a-long-random-hermes-api-key
HERMES_API_SERVER_MODEL=hermes-agent

# Platform knowledge retrieval uses an OpenAI-compatible embedding endpoint.
PLATFORM_KNOWLEDGE_EMBEDDING_API_KEY=replace-with-a-production-embedding-api-key
PLATFORM_KNOWLEDGE_EMBEDDING_ENDPOINT=https://api.openai.com/v1/embeddings
PLATFORM_KNOWLEDGE_EMBEDDING_MODEL=text-embedding-3-small

# AI provider keys are managed in /admin/apikeys and are stored encrypted in the database.
