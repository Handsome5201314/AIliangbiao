# ============================================
# 🗄️ 数据库配置
# ============================================

# PostgreSQL 数据库连接字符串（本地数据库）
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL="postgresql://postgres@localhost:5432/ai_scale_db"

# Prisma 直连数据库（用于数据库迁移和 schema 变更）
# 通常与 DATABASE_URL 相同
DIRECT_URL="postgresql://postgres@localhost:5432/ai_scale_db"

# ============================================
# 🌐 应用基础配置
# ============================================

# 应用访问 URL（生产环境域名）
# ⚠️ 请修改为您的实际域名
NEXT_PUBLIC_APP_URL="http://ailiangbiao.agentpit.io"

# API 访问 URL（通常与 APP_URL 相同）
NEXT_PUBLIC_API_URL="http://ailiangbiao.agentpit.io"

# 应用名称（显示在浏览器标题栏）
NEXT_PUBLIC_APP_NAME="AI 量表系统"

# ============================================
# 🔐 安全配置
# ============================================

# Session 会话加密密钥
# ⚠️ 生产环境必须修改为随机字符串（至少 32 位）
# 生成方法: openssl rand -base64 32
SESSION_SECRET="CHANGE-THIS-TO-A-RANDOM-STRING-IN-PRODUCTION-PLEASE"

# ============================================
# 👤 管理员账户配置
# ============================================

# 管理员用户名
# ⚠️ 建议修改默认用户名以提高安全性
ADMIN_USERNAME="admin"

# 管理员密码
# ⚠️ 生产环境必须修改为强密码
# 建议格式: 至少 8 位，包含大小写字母、数字、特殊字符
# 示例: Admin@2026#Secure
ADMIN_PASSWORD="admin987654321"

# ============================================
# 🤖 AI 服务配置（可选）
# ============================================

# DeepSeek AI API 密钥
# 用途: 提供核心 AI 对话功能
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=""

# 腾讯云 API 配置
# 用途: 提供腾讯混元 AI 服务
# 获取地址: https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=""
TENCENT_SECRET_KEY=""

# ============================================
# 🎤 语音识别配置（可选）
# ============================================

# 腾讯云语音识别服务
# 用途: 提供语音转文字功能
# 获取地址: https://console.cloud.tencent.com/soe
TENCENT_SPEECH_SECRET_ID=""
TENCENT_SPEECH_SECRET_KEY=""

# ============================================
# 🔧 功能开关
# ============================================

# 是否启用语音交互功能
# 值: "true" 启用 | "false" 禁用
ENABLE_VOICE_INTERACTION="true"

# 是否启用 MCP 服务器
# 用途: 提供 AI 模型上下文协议服务
# 值: "true" 启用 | "false" 禁用
ENABLE_MCP_SERVER="true"

# ============================================
# ⚡ 性能优化配置
# ============================================

# 缓存过期时间（秒）
# 默认: 3600 秒（1 小时）
CACHE_TTL="3600"

# 最大缓存数量
# 默认: 1000 条记录
MAX_CACHE_SIZE="1000"

# ============================================
# 📊 日志配置
# ============================================

# 日志级别
# 可选值: "debug" | "info" | "warn" | "error"
# 生产环境建议: "info" 或 "warn"
# 开发环境建议: "debug"
LOG_LEVEL="info"

# ============================================
# 📧 Supabase 配置（可选）
# ============================================

# 如果使用 Supabase 的其他服务（如认证），保留以下配置
# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL="https://vkbevdibozdlfuigksfs.supabase.co"

# Supabase 匿名密钥（公钥，可公开）
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_9jvPCn0mqG7QqgBJwLuKgQ_Q1kPsoD_"

# ============================================
# 📝 配置说明
# ============================================
# 
# 1. 必须修改的配置项（标记 ⚠️）:
#    - SESSION_SECRET: 改为随机字符串
#    - ADMIN_USERNAME: 改为安全的用户名
#    - ADMIN_PASSWORD: 改为强密码
#    - NEXT_PUBLIC_APP_URL: 改为实际域名
#
# 2. 可选配置项:
#    - AI 服务: 如果不使用，可以留空
#    - 语音识别: 如果不使用，可以留空
#    - Supabase: 如果不使用，可以删除相关配置
#
# 3. 修改配置后需要:
#    - 重启应用服务: systemctl restart ai-scale
#    - 或重新部署: ./scripts/deploy-with-domain.sh
#
# 4. 安全建议:
#    - 不要将此文件提交到 Git 仓库
#    - 定期更换 SESSION_SECRET 和管理员密码
#    - 生产环境使用 HTTPS
#
# ============================================
